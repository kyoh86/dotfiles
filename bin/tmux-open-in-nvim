#!/bin/sh
set -eu

kind="${1:-extra}"
split="${2:-none}"

if [ -z "${NVIM_PROXY_URL:-}" ] || [ -z "${NVIM_PID:-}" ]; then
  tmux display-message "nvim-proxy is not available" 2>/dev/null || true
  exit 0
fi

if [ -t 0 ]; then
  selected=""
else
  selected="$(cat || true)"
fi
line="${TMUX_COPY_CURSOR_LINE:-$(tmux display-message -p '#{copy_cursor_line}' 2>/dev/null || true)}"
x="${TMUX_COPY_CURSOR_X:-$(tmux display-message -p '#{copy_cursor_x}' 2>/dev/null || true)}"
cwd="${TMUX_COPY_PANE_CWD:-$(tmux display-message -p '#{pane_current_path}' 2>/dev/null || true)}"

target="$selected"
target="$(printf '%s' "$target" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

payload="$(jq -n \
  --arg kind "$kind" \
  --arg target "$target" \
  --arg line "$line" \
  --arg cursor_col "${x:-0}" \
  --arg split "$split" \
  --arg cwd "$cwd" \
  '{kind:$kind,target:$target,line:$line,cursor_col:($cursor_col | tonumber? // 0),split:$split,cwd:$cwd}')"

if ! curl -fsSL --connect-timeout 0.5 --max-time 2 \
  -H "X-Nvim-Pid: ${NVIM_PID}" \
  -H "content-type: application/json" \
  "${NVIM_PROXY_URL}/open" \
  -d "$payload" >/dev/null 2>&1; then
  tmux display-message "failed to open copy target in Neovim" 2>/dev/null || true
fi
