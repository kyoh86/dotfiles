local function main()
  local repo_path = gogh.repo.full_path
  local claude_md = repo_path .. "/CLAUDE.md"

  local f = io.open(claude_md, "r")
  if f then
    f:close()
    return
  end

  local out = assert(io.open(claude_md, "w"))
  out:write([[
# Repository Guidelines For Claude

- Follow repository-specific instructions in `AGENTS.md` when they exist.
- Never write secrets, API keys, auth tokens, SSH material, cookies, or machine-local credentials into tracked files in this repository.
- Keep Claude local state outside the repository, or in untracked `.claude/**/*.local.*` files only.
]])
  out:close()
  os.execute("chmod 644 " .. claude_md)
end

main()
